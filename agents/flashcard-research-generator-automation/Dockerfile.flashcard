FROM python:3.11-slim

WORKDIR /app

# Cài đặt các thư viện hệ thống cần thiết cho PyMuPDF (fitz) nếu cần
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY autonomous_flashcard_agent.py .

RUN pip install --no-cache-dir \
    requests \
    google-genai \
    beautifulsoup4 \
    pymupdf \
    PyPDF2 \
    python-docx \
    duckduckgo-search \
    tavily-python \
    pydantic

# Để log hiển thị ngay lập tức trong Docker thay vì bị buffer
ENV PYTHONUNBUFFERED=1

CMD ["python", "autonomous_flashcard_agent.py"]
